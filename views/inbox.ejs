<% layout('layouts/boilerplate') %>

<div class="main-content--full">

  <div class="page-header mb-4">
    <h1 class="page-header-title"><i class="fa-solid fa-inbox me-2"></i>My Inbox</h1>
    <p class="page-header-subtitle">Private messages from campus administrators.</p>
  </div>

  <% if (messages.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">📬</div>
      <p class="empty-state-title">No messages yet</p>
      <p class="empty-state-text">When an admin reaches out about a complaint or issue, it will appear here.</p>
    </div>
  <% } %>

  <div class="stagger-children">
    <% messages.forEach(msg => { %>
      <div class="listing-card mb-3 <%= !msg.read ? 'border-primary' : '' %>"
           style="<%= !msg.read ? 'border-width:2px !important' : '' %>">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
              <% if (!msg.read) { %>
                <span class="badge bg-primary mb-2">New</span>
              <% } %>
              <h5 class="fw-bold mb-1"><%= msg.subject %></h5>
              <div class="text-muted small mb-2">
                From <strong><%= msg.fromAdminName %></strong> (Admin)
                · <%= new Date(msg.createdAt).toLocaleString('en-IN') %>
              </div>
            </div>
          </div>
          <p class="text-secondary mb-0" style="white-space:pre-wrap"><%= msg.content %></p>
          <% if (!msg.read) { %>
            <form action="/inbox/<%= msg._id %>/read" method="POST" class="mt-3">
              <button type="submit" class="btn btn-sm btn-outline-primary">Mark as Read</button>
            </form>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>

</div>
