<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Campus Puzzle — Login</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="login-page">

  <div class="login-overlay">
    <div class="login-card">

      <div class="login-header">
        <div class="login-icon">&#127979;</div>
        <h1>Campus Puzzle</h1>
        <p>Sign in with your college credentials</p>
      </div>

      <% if (error) { %>
        <div class="login-error">
          <span>&#9888;</span> <%= error %>
        </div>
      <% } %>

      <form action="/login" method="POST">

        <div class="form-group">
          <label for="email">College email</label>
          <input type="email" id="email" name="email"
                 placeholder="you@college.edu" required autofocus/>
        </div>

        <div class="form-group">
          <label for="rollNumber">Roll number</label>
          <input type="text" id="rollNumber" name="rollNumber"
                 placeholder="e.g. 21CS001" required/>
        </div>

        <button type="submit" class="login-btn">Sign in &rarr;</button>

      </form>

      <p class="login-note">Only registered students can access this app.</p>

    </div>
  </div>

</body>
</html>