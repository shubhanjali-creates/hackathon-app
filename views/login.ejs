<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CampusLive — Sign In</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="login-page">

  <div class="login-bg"></div>
  <div class="login-bg-shapes">
    <div class="login-shape login-shape-1"></div>
    <div class="login-shape login-shape-2"></div>
    <div class="login-shape login-shape-3"></div>
  </div>

  <div class="login-overlay">
    <div class="login-card">

      <div class="login-header">
        <div class="login-logo">🎓</div>
        <h1>CampusLive</h1>
        <p>Your all-in-one campus companion</p>
      </div>

      <% if (error) { %>
        <div class="login-error">
          <span>⚠</span> <%= error %>
        </div>
      <% } %>

      <form action="/login" method="POST">

        <div class="form-group">
          <label for="email">College email</label>
          <input type="email" id="email" name="email"
                 placeholder="you@college.edu" required autofocus/>
        </div>

        <div class="form-group">
          <label for="rollNumber">Roll number</label>
          <input type="text" id="rollNumber" name="rollNumber"
                 placeholder="e.g. 21CS001" required/>
        </div>

        <button type="submit" class="login-btn">
          Sign in <i class="fa-solid fa-arrow-right" style="font-size:0.85em"></i>
        </button>

      </form>

      <p class="login-note">Only registered students can access this app.</p>

    </div>
  </div>

</body>
</html>
