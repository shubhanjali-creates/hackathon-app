<% layout('layouts/boilerplate') %>

<div class="main-content--full">

  <div class="page-header mb-4">
    <h1 class="page-header-title"><i class="fa-solid fa-flag me-2"></i>All Complaints</h1>
    <p class="page-header-subtitle">Admin view — student identities are visible here so you can follow up privately. Students still see complaints as anonymous on the public page.</p>
  </div>

  <% if (typeof sent !== 'undefined') { %><% } %>
  <script>
    if (new URLSearchParams(window.location.search).get('sent')) {
      document.write('<div class="alert alert-success mb-4">Message sent to student successfully.</div>');
    }
  </script>

  <div class="d-flex flex-wrap gap-2 mb-4">
    <a href="/admin/complaints?filter=all"
       class="btn btn-sm <%= filter === 'all' ? 'btn-primary-app' : 'btn-outline-secondary' %>">
      All (<%= openCount + resolvedCount %>)
    </a>
    <a href="/admin/complaints?filter=open"
       class="btn btn-sm <%= filter === 'open' ? 'btn-primary-app' : 'btn-outline-secondary' %>">
      Open (<%= openCount %>)
    </a>
    <a href="/admin/complaints?filter=resolved"
       class="btn btn-sm <%= filter === 'resolved' ? 'btn-primary-app' : 'btn-outline-secondary' %>">
      Resolved (<%= resolvedCount %>)
    </a>
  </div>

  <% if (complaints.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">📋</div>
      <p class="empty-state-title">No complaints in this view</p>
    </div>
  <% } %>

  <div class="stagger-children">
    <% complaints.forEach(c => { %>
      <div class="listing-card mb-3 <%= c.resolved ? 'complaint-card-resolved' : '' %>">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div class="flex-grow-1">
              <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                <span class="complaint-category"><%= c.complaintCategory %></span>
                <% if (c.resolved) { %>
                  <span class="complaint-resolved-tag"><i class="fa-solid fa-check me-1"></i>Resolved</span>
                <% } else { %>
                  <span class="badge bg-warning text-dark">Open</span>
                <% } %>
              </div>
              <h5 class="complaint-title mt-2"><%= c.complaintTitle %></h5>
              <% if (c.imageUrl) { %>
                <div class="post-image-wrap mb-2">
                  <img src="<%= c.imageUrl %>" alt="Complaint attachment" class="post-image" loading="lazy">
                </div>
              <% } %>
              <p class="text-secondary mb-2"><%= c.details %></p>
              <div class="text-muted small">
                <i class="fa-solid fa-user me-1"></i>
                <strong><%= c.postedBy %></strong>
                <% if (c.studentId) { %>
                  · <%= c.studentId.email %> · <%= c.studentId.rollNumber %>
                <% } %>
                · Submitted <%= new Date(c.createdAt).toLocaleString('en-IN') %>
                <% if (c.resolved && c.resolvedAt) { %>
                  · Resolved <%= new Date(c.resolvedAt).toLocaleString('en-IN') %>
                <% } %>
              </div>
            </div>
            <% if (c.studentId && c.studentId._id) { %>
              <a href="/admin/message/<%= c.studentId._id %>?complaint=<%= c._id %>"
                 class="btn btn-primary-app btn-sm align-self-start">
                <i class="fa-solid fa-envelope me-1"></i>Message Student
              </a>
            <% } else { %>
              <span class="text-muted small">No linked student account</span>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <div class="mt-4">
    <a href="/admin" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i> Back to Admin</a>
  </div>

</div>
