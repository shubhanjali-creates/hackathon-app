<% layout('layouts/boilerplate') %>

<div class="main-content--full">

  <div class="page-header page-header--hero mb-4">
    <h1 class="page-header-title"><i class="fa-solid fa-shield-halved me-2"></i>Admin Panel</h1>
    <p class="page-header-subtitle">Platform-wide control — moderate posts, manage clubs, and support students.</p>
  </div>

  <div class="row g-4 mb-5">
    <div class="col-md-3 col-6">
      <div class="listing-card">
        <div class="card-body text-center">
          <div class="display-6 fw-bold text-primary"><%= postCount %></div>
          <div class="text-muted small">Total Posts</div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="listing-card">
        <div class="card-body text-center">
          <div class="display-6 fw-bold text-danger"><%= complaintCount %></div>
          <div class="text-muted small">Complaints</div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="listing-card">
        <div class="card-body text-center">
          <div class="display-6 fw-bold text-success"><%= studentCount %></div>
          <div class="text-muted small">Students</div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="listing-card">
        <div class="card-body text-center">
          <div class="display-6 fw-bold text-info"><%= clubCount %></div>
          <div class="text-muted small">Clubs</div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-4">
      <div class="listing-card h-100">
        <div class="card-body">
          <h5 class="fw-bold mb-3"><i class="fa-solid fa-users-gear me-2 text-primary"></i>Club Leaders</h5>
          <p class="text-muted small">Appoint or remove heads of clubs.</p>
          <a href="/admin/appoint" class="btn btn-primary-app btn-sm">Manage Leaders</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="listing-card h-100">
        <div class="card-body">
          <h5 class="fw-bold mb-3"><i class="fa-solid fa-flag me-2 text-danger"></i>Complaints</h5>
          <p class="text-muted small">Review complaints and message students directly.</p>
          <a href="/admin/complaints" class="btn btn-primary-app btn-sm">View Complaints</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="listing-card h-100">
        <div class="card-body">
          <h5 class="fw-bold mb-3"><i class="fa-solid fa-house me-2 text-success"></i>Campus Feed</h5>
          <p class="text-muted small">Pin or delete any post across the platform.</p>
          <a href="/" class="btn btn-primary-app btn-sm">Go to Feed</a>
        </div>
      </div>
    </div>
  </div>

  <h4 class="fw-bold mt-5 mb-3">Club Leadership Overview</h4>
  <div class="row g-3">
    <% clubs.forEach(club => { %>
      <div class="col-md-6">
        <div class="listing-card">
          <div class="card-body d-flex justify-content-between align-items-center">
            <div>
              <span class="me-2"><%= club.emoji %></span>
              <strong><%= club.name %></strong>
              <div class="text-muted small mt-1">
                <% if (club.leaderId) { %>
                  Leader: <%= club.leaderId.name %> (<%= club.leaderId.rollNumber %>)
                <% } else { %>
                  <span class="text-warning">No leader assigned</span>
                <% } %>
              </div>
            </div>
            <a href="/clubs/<%= club._id %>" class="btn btn-sm btn-outline-secondary">View Club</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>
