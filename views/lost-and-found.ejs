<% layout('layouts/boilerplate') %>

<%- include('partials/sidebar') %>

<div class="main-content">

  <div class="page-header">
    <h1 class="page-header-title">🔍 Lost & Found</h1>
    <p class="page-header-subtitle">Lost something or found something on campus? Report it here.</p>
  </div>

  <div class="form-card">
    <h5 class="form-card-title"><i class="fa-solid fa-magnifying-glass"></i> Report an Item</h5>
    <form action="/lost-and-found" method="POST" enctype="multipart/form-data">
      <div class="row g-3">
        <%- include('partials/post-form-core') %>
        <div class="col-md-4">
          <label class="form-label small fw-semibold">Status</label>
          <select name="type" class="form-select w-100" required>
            <option value="">Lost or Found?</option>
            <option value="Lost">🔴 Lost</option>
            <option value="Found">🟢 Found</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label small fw-semibold">Location</label>
          <input type="text" name="location" class="form-control w-100" placeholder="Where?" required />
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-accent">
            <i class="fa-solid fa-paper-plane me-2"></i>Submit Report
          </button>
        </div>
      </div>
    </form>
  </div>

  <div class="row g-4 stagger-children">
    <% if (posts.length === 0) { %>
      <div class="col-12">
        <div class="empty-state">
          <div class="empty-state-icon">🔍</div>
          <p class="empty-state-title">No reports yet</p>
          <p class="empty-state-text">Help reunite lost items with their owners!</p>
        </div>
      </div>
    <% } %>
    <% posts.forEach(post => { %>
      <div class="col-md-6">
        <div class="listing-card">
          <div class="card-body">
            <% const status = post.itemStatus || post.type2 || 'Found'; %>
            <span class="tag-badge <%= status === 'Lost' ? 'tag-lost' : 'tag-cab' %> mb-2 d-inline-block">
              <%= status === 'Lost' ? '🔴 Lost' : '🟢 Found' %>
            </span>
            <div class="listing-card-title"><%= post.title || post.itemName %></div>
            <%- include('partials/post-hashtags', { post }) %>
            <%- include('partials/post-image', { post }) %>
            <div class="listing-card-meta"><i class="fa-solid fa-location-dot"></i> <%= post.location %></div>
            <p class="text-secondary mt-2 mb-0" style="font-size:0.9rem"><%= post.details %></p>
            <div class="listing-card-footer">
              <i class="fa-solid fa-user me-1"></i> Posted by <%= post.postedBy %>
            </div>
            <%- include('partials/post-actions', { post, redirectPath: '/lost-and-found' }) %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>
