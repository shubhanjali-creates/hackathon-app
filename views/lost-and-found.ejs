<% layout('layouts/boilerplate') %>

<div class="container mt-4">
  <h2 class="fw-bold mb-1">🔍 Lost & Found</h2>
  <p class="text-muted mb-4">Lost something or found something on campus?</p>

  <!-- Post a lost or found item -->
  <div class="card bg-dark text-white mb-4 p-3">
    <h5 class="mb-3">Report an Item</h5>
    <form action="/lost-and-found" method="POST">
      <div class="mb-2">
        <select name="type" class="form-select" required>
          <option value="">Lost or Found?</option>
          <option value="Lost">Lost</option>
          <option value="Found">Found</option>
        </select>
      </div>
      <div class="mb-2">
        <input type="text" name="itemName" class="form-control" placeholder="What is the item?" required />
      </div>
      <div class="mb-2">
        <input type="text" name="location" class="form-control" placeholder="Where was it lost or found?" required />
      </div>
      <div class="mb-2">
        <input type="text" name="postedBy" class="form-control" placeholder="Your name" required />
      </div>
      <div class="mb-3">
        <textarea name="details" class="form-control" rows="2" placeholder="Any extra details to identify it"></textarea>
      </div>
      <button type="submit" class="btn btn-warning fw-bold">Submit Report</button>
    </form>
  </div>

  <!-- List of reports -->
  <div class="row">
    <% if (posts.length === 0) { %>
      <p class="text-muted">No reports yet.</p>
    <% } %>
    <% posts.forEach(post => { %>
      <div class="col-md-6 mb-3">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <span class="badge <%= post.type === 'Lost' ? 'bg-danger' : 'bg-success' %> mb-2">
              <%= post.type %>
            </span>
            <h5 class="card-title"><%= post.itemName %></h5>
            <p class="text-muted mb-1">📍 <%= post.location %></p>
            <p class="card-text"><%= post.details %></p>
            <small class="text-muted">Posted by <%= post.postedBy %></small>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>