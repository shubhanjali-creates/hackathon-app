<% layout('layouts/boilerplate') %>

<%- include('partials/sidebar') %>

<div class="main-content">

  <div class="page-header">
    <h1 class="page-header-title">📝 Complaints</h1>
    <p class="page-header-subtitle">Report campus issues anonymously. Only you can mark your own complaints as resolved.</p>
  </div>

  <% if (justResolved) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="fa-solid fa-check-circle me-2"></i>Your complaint has been marked as resolved.
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <% if (currentRole === 'admin') { %>
    <div class="alert alert-info d-flex align-items-center justify-content-between flex-wrap gap-2">
      <span><i class="fa-solid fa-shield-halved me-2"></i>You are viewing the <strong>student</strong> complaints page (anonymous). See full details with student identities in the admin panel.</span>
      <a href="/admin/complaints" class="btn btn-sm btn-primary-app">Admin Complaints</a>
    </div>
  <% } %>

  <div class="info-box">
    <strong><i class="fa-solid fa-shield-halved me-2"></i>Anonymous Reporting</strong>
    <p>Your name is never shown to other students. When an issue is fixed, use <strong>Mark as Resolved</strong> on your complaint — only you will see that option.</p>
  </div>

  <div class="form-card">
    <h5 class="form-card-title"><i class="fa-solid fa-flag"></i> Submit a Complaint</h5>
    <form action="/complaints" method="POST" enctype="multipart/form-data">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label text-white-50 small">Category</label>
          <select name="complaintCategory" class="form-select w-100" required>
            <option value="">Choose Category</option>
            <option>Academic</option>
            <option>Hostel</option>
            <option>Mess</option>
            <option>Library</option>
            <option>Campus Facilities</option>
            <option>Sports</option>
            <option>Safety</option>
            <option>Other</option>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label text-white-50 small">Complaint Title</label>
          <input type="text" class="form-control w-100" name="complaintTitle"
                 placeholder="Brief title for your complaint" required>
        </div>
        <div class="col-12">
          <label class="form-label text-white-50 small">Describe the Issue</label>
          <textarea class="form-control w-100" rows="4" name="details"
                    placeholder="Explain your complaint in detail..." required></textarea>
        </div>
        <div class="col-12">
          <%- include('partials/image-upload-field') %>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-danger fw-bold px-4">
            <i class="fa-solid fa-paper-plane me-2"></i>Submit Complaint
          </button>
        </div>
      </div>
    </form>
  </div>

  <% if (myComplaints && myComplaints.length > 0) { %>
    <h2 class="h5 fw-bold mt-5 mb-3">
      <i class="fa-solid fa-user-lock me-2 text-primary"></i>Your Complaints
      <span class="text-muted fw-normal small">(visible only to you)</span>
    </h2>
    <div class="row g-4 mb-5">
      <% myComplaints.forEach(post => { %>
        <div class="col-md-6">
          <div class="complaint-card complaint-card-mine <%= post.resolved ? 'complaint-card-resolved' : '' %>">
            <div class="card-body p-4">
              <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                <span class="complaint-category"><%= post.complaintCategory %></span>
                <%- include('partials/complaint-resolved-tag', { complaint: post }) %>
              </div>
              <span class="complaint-mine-label"><i class="fa-solid fa-user-secret me-1"></i>Your complaint</span>
              <h5 class="complaint-title"><%= post.complaintTitle %></h5>
              <% if (post.imageUrl) { %>
                <div class="post-image-wrap mb-2">
                  <img src="<%= post.imageUrl %>" alt="Complaint attachment" class="post-image" loading="lazy">
                </div>
              <% } %>
              <p class="text-secondary mb-0" style="font-size:0.9rem"><%= post.details %></p>
              <% if (!post.resolved) { %>
                <form action="/complaints/<%= post._id %>/resolve" method="POST" class="mt-3"
                      onsubmit="return confirm('Mark this complaint as resolved?')">
                  <button type="submit" class="btn btn-sm btn-success">
                    <i class="fa-solid fa-check me-1"></i>Mark as Resolved
                  </button>
                </form>
              <% } else if (post.resolvedAt) { %>
                <p class="text-muted small mt-3 mb-0">
                  Resolved on <%= new Date(post.resolvedAt).toLocaleString('en-IN') %>
                </p>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <h2 class="h5 fw-bold mb-3"><i class="fa-solid fa-list me-2"></i>All Complaints</h2>

  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">📋</div>
      <p class="empty-state-title">No complaints submitted yet</p>
      <p class="empty-state-text">Be the first to raise an issue and help improve campus life.</p>
    </div>
  <% } %>

  <div class="row g-4 stagger-children">
    <% posts.forEach(post => { %>
      <div class="col-md-6">
        <div class="complaint-card <%= post.resolved ? 'complaint-card-resolved' : '' %>">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
              <span class="complaint-category"><%= post.complaintCategory %></span>
              <%- include('partials/complaint-resolved-tag', { complaint: post }) %>
            </div>
            <h5 class="complaint-title"><%= post.complaintTitle %></h5>
            <% if (post.imageUrl) { %>
              <div class="post-image-wrap mb-2">
                <img src="<%= post.imageUrl %>" alt="Complaint attachment" class="post-image" loading="lazy">
              </div>
            <% } %>
            <p class="text-secondary mb-0" style="font-size:0.9rem"><%= post.details %></p>
            <div class="complaint-anonymous">
              <i class="fa-solid fa-user-secret"></i> Anonymous Student
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>
