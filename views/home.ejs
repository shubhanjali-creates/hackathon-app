<% layout('layouts/boilerplate') %>

<%- include('partials/sidebar') %>

<div class="main-content">

  <div class="page-header page-header--hero">
    <h1 class="page-header-title">Campus Feed</h1>
    <p class="page-header-subtitle">See what's happening around campus — food orders, cab splits, resells, and more.</p>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h5 fw-bold mb-0"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Recent Posts</h2>
    <span class="badge bg-light text-secondary border"><%= posts.length %> post<%= posts.length !== 1 ? 's' : '' %></span>
  </div>

  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">📭</div>
      <p class="empty-state-title">No posts yet</p>
      <p class="empty-state-text">Be the first to share something with your campus community!</p>
    </div>
  <% } %>

  <div class="stagger-children">
    <% posts.forEach(post => { %>
      <div class="feed-card <%= post.pinned ? 'feed-card-pinned' : '' %>">
        <div class="card-body">

          <% if (post.pinned) { %>
            <div class="pinned-label mb-2">
              <i class="fa-solid fa-thumbtack me-1"></i> Pinned by Admin
            </div>
          <% } %>

          <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="d-flex align-items-center gap-3">
              <div class="feed-avatar">
                <%= post.postedBy.charAt(0).toUpperCase() %>
              </div>
              <div>
                <div class="feed-author"><%= post.postedBy %></div>
                <div class="feed-time">
                  <i class="fa-regular fa-clock"></i>
                  <%= new Date(post.createdAt).toLocaleString('en-IN', {
                    day: 'numeric', month: 'short',
                    hour: '2-digit', minute: '2-digit'
                  }) %>
                </div>
              </div>
            </div>

            <span class="tag-badge
              <%= post.type === 'food'  ? 'tag-food'   : '' %>
              <%= post.type === 'cab'   ? 'tag-cab'    : '' %>
              <%= post.type === 'resell'? 'tag-resell' : '' %>
              <%= post.type === 'lost'  ? 'tag-lost'   : '' %>
              <%= !['food','cab','resell','lost'].includes(post.type) ? 'tag-general' : '' %>
            ">
              <%= post.type === 'food'   ? '🍕 Food'         : '' %>
              <%= post.type === 'cab'    ? '🚗 Cab'          : '' %>
              <%= post.type === 'resell' ? '🛍️ Resell'       : '' %>
              <%= post.type === 'lost'   ? '🔍 Lost & Found' : '' %>
              <%= !['food','cab','resell','lost'].includes(post.type) ? '📌 General' : '' %>
            </span>
          </div>

          <p class="feed-content mb-0">
            <% if (post.type === 'food') { %>
              <strong><%= post.title %></strong> — <%= post.location %>
              <% if (post.details) { %><br><%= post.details %><% } %>
            <% } else if (post.type === 'cab') { %>
              <strong><%= post.destination %></strong> · leaving <%= post.leavingAt %> · <%= post.seatsAvailable %> seats
              <% if (post.details) { %><br><%= post.details %><% } %>
            <% } else if (post.type === 'resell') { %>
              <strong><%= post.itemName %></strong> — ₹<%= post.price %> (<%= post.condition %>)
              <% if (post.details) { %><br><%= post.details %><% } %>
            <% } else if (post.type === 'lost') { %>
              <strong><%= post.itemName %></strong> — <%= post.location %>
              <% if (post.details) { %><br><%= post.details %><% } %>
            <% } else { %>
              <%= post.details || post.complaintTitle || 'New campus post' %>
            <% } %>
          </p>

          <%- include('partials/post-actions', { post, redirectPath: '/' }) %>

        </div>
      </div>
    <% }) %>
  </div>

</div>

<button class="floating-btn" onclick="toggleModal()">
  <i class="fa-solid fa-pen"></i> Post
</button>

<div class="overlay" id="overlay" onclick="toggleModal()"></div>

<div class="post-modal" id="postModal">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="post-modal-title mb-0"><i class="fa-solid fa-bullhorn me-2"></i>Create a Post</h5>
    <button onclick="toggleModal()" class="btn-close btn-close-white" aria-label="Close"></button>
  </div>

  <form action="/home" method="POST">

    <div class="mb-3">
      <textarea name="content" class="form-control" rows="4"
                placeholder="What's happening on campus?" required></textarea>
    </div>

    <div class="mb-4">
      <select name="tag" class="form-select">
        <option value="general">📌 General</option>
        <option value="food">🍕 Food</option>
        <option value="cab">🚗 Cab</option>
        <option value="resell">🛍️ Resell</option>
        <option value="lost">🔍 Lost & Found</option>
      </select>
    </div>

    <button type="submit" class="btn btn-accent w-100">
      <i class="fa-solid fa-paper-plane me-2"></i>Post to Feed
    </button>

  </form>
</div>

<script>
  function toggleModal() {
    document.getElementById('postModal').classList.toggle('active');
    document.getElementById('overlay').classList.toggle('active');
  }
</script>
