<% layout('layouts/boilerplate') %>

<%- include('partials/sidebar') %>

<div class="main-content">

  <div class="page-header">
    <h1 class="page-header-title">🛍️ Resell</h1>
    <p class="page-header-subtitle">Buy and sell second-hand items on campus</p>
  </div>

  <div class="form-card">
    <h5 class="form-card-title"><i class="fa-solid fa-tag"></i> List an Item</h5>
    <form action="/resell" method="POST">
      <div class="row g-3">
        <div class="col-md-6">
          <input type="text" name="itemName" class="form-control w-100"
                 placeholder="What are you selling?" required />
        </div>
        <div class="col-md-3">
          <input type="number" name="price" class="form-control w-100"
                 placeholder="Price in ₹" required />
        </div>
        <div class="col-md-3">
          <input type="text" name="condition" class="form-control w-100"
                 placeholder="Condition (New/Good/Fair)" required />
        </div>
        <div class="col-12">
          <textarea name="details" class="form-control w-100" rows="2"
                    placeholder="More details about the item"></textarea>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-accent">
            <i class="fa-solid fa-plus me-2"></i>List Item
          </button>
        </div>
      </div>
    </form>
  </div>

  <div class="row g-4 stagger-children">
    <% if (posts.length === 0) { %>
      <div class="col-12">
        <div class="empty-state">
          <div class="empty-state-icon">🛍️</div>
          <p class="empty-state-title">Nothing listed yet</p>
          <p class="empty-state-text">Be the first to list an item for sale!</p>
        </div>
      </div>
    <% } %>
    <% posts.forEach(post => { %>
      <div class="col-md-4">
        <div class="listing-card">
          <div class="card-body">
            <div class="listing-card-title"><%= post.itemName %></div>
            <div class="listing-price mb-2">₹<%= post.price %></div>
            <div class="listing-card-meta">
              <i class="fa-solid fa-star"></i> Condition: <%= post.condition %>
            </div>
            <% if (post.details || post.description) { %>
              <p class="text-secondary mt-2 mb-0" style="font-size:0.9rem"><%= post.details || post.description %></p>
            <% } %>
            <div class="listing-card-footer">
              <i class="fa-solid fa-user me-1"></i> Posted by <%= post.postedBy %>
            </div>
            <%- include('partials/post-actions', { post, redirectPath: '/resell' }) %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>
