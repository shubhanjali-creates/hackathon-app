<% layout('layouts/boilerplate') %>

<div class="container mt-4">
  <h2 class="fw-bold mb-1">🛍️ Resell</h2>
  <p class="text-muted mb-4">Buy and sell second hand stuff on campus</p>

  <!-- Post a resell item -->
  <div class="card bg-dark text-white mb-4 p-3">
    <h5 class="mb-3">List an Item</h5>
    <form action="/resell" method="POST">
      <div class="mb-2">
        <input type="text" name="itemName" class="form-control" placeholder="What are you selling?" required />
      </div>
      <div class="mb-2">
        <input type="number" name="price" class="form-control" placeholder="Price in ₹" required />
      </div>
      <div class="mb-2">
        <input type="text" name="condition" class="form-control" placeholder="Condition (New / Good / Fair)" required />
      </div>
      <div class="mb-2">
        <input type="text" name="postedBy" class="form-control" placeholder="Your name" required />
      </div>
      <div class="mb-3">
        <textarea name="details" class="form-control" rows="2" placeholder="More details about the item"></textarea>
      </div>
      <button type="submit" class="btn btn-warning fw-bold">List Item</button>
    </form>
  </div>

  <!-- List of items -->
  <div class="row">
    <% if (posts.length === 0) { %>
      <p class="text-muted">Nothing listed yet. Be the first!</p>
    <% } %>
    <% posts.forEach(post => { %>
      <div class="col-md-4 mb-3">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="card-title">🛍️ <%= post.itemName %></h5>
            <h6 class="text-success fw-bold">₹<%= post.price %></h6>
            <p class="text-muted mb-1">Condition: <%= post.condition %></p>
            <p class="card-text"><%= post.details %></p>
            <small class="text-muted">Posted by <%= post.postedBy %></small>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>