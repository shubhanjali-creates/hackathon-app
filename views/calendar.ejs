<% layout('layouts/boilerplate') %>
<% const weekDays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"]; %>
<% const totalCells = Math.ceil((startWeekday + daysInMonth) / 7) * 7; %>
<% const allEventsThisMonth = Object.values(eventsByDay).flat(); %>

<div class="calendar-page">

  <div class="calendar-toolbar">
    <h1 class="calendar-month-title mb-0">
      <i class="fa-solid fa-calendar-days me-2" style="color:var(--primary)"></i>
      <%= monthNames[month] %> <%= year %>
    </h1>

    <div class="d-flex gap-2 flex-wrap calendar-nav">
      <div class="btn-group">
        <a href="/calendar?month=<%= prevMonth %>&year=<%= prevYear %>" class="btn btn-outline-secondary">
          <i class="fa-solid fa-chevron-left"></i>
        </a>
        <a href="/calendar" class="btn btn-outline-secondary">Today</a>
        <a href="/calendar?month=<%= nextMonth %>&year=<%= nextYear %>" class="btn btn-outline-secondary">
          <i class="fa-solid fa-chevron-right"></i>
        </a>
      </div>
      <% if (currentRole === "club" || currentRole === "admin") { %>
        <button class="btn btn-primary-app" data-bs-toggle="modal" data-bs-target="#addEventModal">
          <i class="fa-solid fa-plus me-1"></i> Add Event
        </button>
      <% } %>
    </div>
  </div>

  <div class="calendar-grid">
    <% weekDays.forEach(function(wd) { %>
      <div class="calendar-header"><%= wd %></div>
    <% }); %>

    <% for (let i = 0; i < totalCells; i++) {
         const dayNum = i - startWeekday + 1;
         const isCurrentMonth = dayNum >= 1 && dayNum <= daysInMonth;
         const isToday = isCurrentMonth
            && today.getDate() === dayNum
            && today.getMonth() === month
            && today.getFullYear() === year;
    %>
      <div class="calendar-cell <%= !isCurrentMonth ? 'calendar-cell-empty' : '' %> <%= isToday ? 'calendar-cell-today' : '' %>">
        <% if (isCurrentMonth) { %>
          <div class="calendar-date"><%= dayNum %></div>
          <% if (eventsByDay[dayNum]) { %>
            <% eventsByDay[dayNum].forEach(function(ev) { %>
              <div class="calendar-event" title="<%= ev.description || '' %>">
                <%= ev.title %><% if (ev.startTime) { %> · <%= ev.startTime %><% } %>
              </div>
            <% }); %>
          <% } %>
        <% } %>
      </div>
    <% } %>
  </div>

  <h2 class="events-section-title">
    <i class="fa-solid fa-list me-2"></i>Events This Month
  </h2>

  <% if (allEventsThisMonth.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">📅</div>
      <p class="empty-state-title">No events scheduled yet</p>
      <p class="empty-state-text">Be the first to add one!</p>
    </div>
  <% } else { %>
    <div class="stagger-children">
      <% allEventsThisMonth.forEach(function(ev) { %>
        <div class="event-list-item">
          <div>
            <div class="event-list-title"><%= ev.title %></div>
            <div class="event-list-meta">
              <i class="fa-regular fa-calendar me-1"></i><%= ev.date.toDateString() %>
              <% if (ev.startTime) { %>, <%= ev.startTime %><% if (ev.endTime) { %>–<%= ev.endTime %><% } %><% } %>
              <% if (ev.location) { %> · <i class="fa-solid fa-location-dot me-1"></i><%= ev.location %><% } %>
            </div>
            <% if (ev.description) { %>
              <p class="text-secondary mb-0 mt-2" style="font-size:0.875rem"><%= ev.description %></p>
            <% } %>
          </div>
          <% if (ev.club) { %>
            <span class="badge rounded-pill" style="background:#eef2ff;color:var(--primary-dark)"><%= ev.club %></span>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>

</div>

<!-- Add Event Modal -->
<div class="modal fade" id="addEventModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius:var(--radius-xl)">
      <form action="/calendar/events" method="POST">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold"><i class="fa-solid fa-calendar-plus me-2 text-primary"></i>Add an Event</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body pt-3">
          <div class="mb-3">
            <label class="form-label fw-semibold small">Event Title</label>
            <input type="text" name="title" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">Date</label>
            <input type="date" name="date" class="form-control" required>
          </div>
          <div class="row">
            <div class="col mb-3">
              <label class="form-label fw-semibold small">Start Time</label>
              <input type="time" name="startTime" class="form-control">
            </div>
            <div class="col mb-3">
              <label class="form-label fw-semibold small">End Time</label>
              <input type="time" name="endTime" class="form-control">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">Location</label>
            <input type="text" name="location" class="form-control" placeholder="e.g. Auditorium, Block C">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">Organizing Club</label>
            <% if (currentRole === 'club' && leaderClub) { %>
              <input type="text" class="form-control" value="<%= leaderClub.emoji %> <%= leaderClub.name %>" disabled>
              <small class="text-muted">Club leaders can only add events for their own club.</small>
            <% } else { %>
              <input type="text" name="club" class="form-control" placeholder="Club name (optional)">
            <% } %>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold small">Description</label>
            <textarea name="description" class="form-control" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary-app">Add Event</button>
        </div>
      </form>
    </div>
  </div>
</div>
