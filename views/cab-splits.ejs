<% layout('layouts/boilerplate') %>

<%- include('partials/sidebar') %>

<div class="main-content">

  <div class="page-header">
    <h1 class="page-header-title">🚗 Cab Splits</h1>
    <p class="page-header-subtitle">Find travel buddies — posts auto-delete when the timer ends.</p>
  </div>

  <div class="form-card">
    <h5 class="form-card-title"><i class="fa-solid fa-car"></i> Post a Cab Split</h5>
    <form action="/cab-splits" method="POST" enctype="multipart/form-data">
      <div class="row g-3">
        <%- include('partials/post-form-core') %>
        <div class="col-md-6">
          <label class="form-label small fw-semibold">Destination</label>
          <input type="text" name="destination" class="form-control w-100" placeholder="Where are you going?" required />
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Leaving at</label>
          <input type="text" name="leavingAt" class="form-control w-100" placeholder="Time" required />
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Seats</label>
          <input type="number" name="seatsAvailable" class="form-control w-100" placeholder="Available" required />
        </div>
        <div class="col-md-6">
          <%- include('partials/lifespan-field') %>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-accent">
            <i class="fa-solid fa-plus me-2"></i>Post Cab Split
          </button>
        </div>
      </div>
    </form>
  </div>

  <div class="row g-4 stagger-children">
    <% if (posts.length === 0) { %>
      <div class="col-12">
        <div class="empty-state">
          <div class="empty-state-icon">🚗</div>
          <p class="empty-state-title">No cab splits right now</p>
          <p class="empty-state-text">Post one above and find travel buddies!</p>
        </div>
      </div>
    <% } %>
    <% posts.forEach(post => { %>
      <div class="col-md-6">
        <div class="listing-card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
              <div class="listing-card-title">🚗 <%= post.title %></div>
              <%- include('partials/post-countdown', { post }) %>
            </div>
            <%- include('partials/post-hashtags', { post }) %>
            <%- include('partials/post-image', { post }) %>
            <div class="listing-card-meta"><i class="fa-solid fa-car me-1"></i> <%= post.destination %></div>
            <div class="listing-card-meta"><i class="fa-regular fa-clock"></i> Leaving at <%= post.leavingAt %></div>
            <div class="listing-card-meta"><i class="fa-solid fa-chair"></i> <%= post.seatsAvailable %> seat<%= post.seatsAvailable != 1 ? 's' : '' %> available</div>
            <p class="text-secondary mt-2 mb-0" style="font-size:0.9rem"><%= post.details %></p>
            <div class="listing-card-footer">
              <i class="fa-solid fa-user me-1"></i> Posted by <%= post.postedBy %>
            </div>
            <%- include('partials/post-actions', { post, redirectPath: '/cab-splits' }) %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>
