<% layout('layouts/boilerplate') %>

<% const clubColors = ['#6366f1','#10b981','#f59e0b','#ef4444','#06b6d4','#8b5cf6','#ec4899','#14b8a6']; %>

<div class="main-content--full">

  <div class="page-header page-header--hero mb-4">
    <h1 class="page-header-title">🏛️ Clubs & Committees</h1>
    <p class="page-header-subtitle">Join conversations, get announcements, and connect with your community.</p>
  </div>

  <div class="row g-4 stagger-children">

    <% clubs.forEach(function(club, i) { %>
      <% const color = clubColors[i % clubColors.length]; %>

      <div class="col-md-4 col-sm-6">
        <a href="/clubs/<%= club._id %>" class="text-decoration-none">
          <div class="club-card" style="--club-color: <%= color %>;">

            <div class="club-emoji"><%= club.emoji %></div>

            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
              <span class="club-name"><%= club.name %></span>
              <span class="club-category"><%= club.category %></span>
            </div>

            <p class="club-description mb-0"><%= club.description %></p>

            <% if (club.leaderId) { %>
              <div class="text-muted small mt-2">
                <i class="fa-solid fa-crown me-1"></i> Led by <%= club.leaderId.name %>
              </div>
            <% } %>

            <div class="club-cta">
              Open Chat <i class="fa-solid fa-arrow-right"></i>
            </div>

          </div>
        </a>
      </div>

    <% }) %>

  </div>

</div>
