</div>

<script>
  document.querySelectorAll('.sidebar-link').forEach(link => {
    const href = link.getAttribute('href');
    if (href === window.location.pathname ||
        (href !== '/' && window.location.pathname.startsWith(href))) {
      link.classList.add('active');
    }
  });
</script>
